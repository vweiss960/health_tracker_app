# Copy this to .env and fill in your values
# Generate a secret key with: python3 -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=your-secret-key-here

# Optional: set to 'true' if behind an HTTPS reverse proxy (enables Secure cookies, HSTS)
# HTTPS_ENABLED=true

# Optional: set to 'development' to enable debug mode and debug endpoints
# FLASK_ENV=development

# Optional: promote a user to admin on startup (remove after first use)
ADMIN_USER=my_admin_user

# Optional: disable public registration
# DISABLE_REGISTRATION=true

# Optional: set to number of reverse proxies in front of the app (e.g. 1 for nginx/Caddy)
# This ensures rate limiting, IP blocking, and geo lookup use the real client IP
# PROXY_COUNT=1
